# ╔══════════════════════════════════════════════════════════════════╗
# ║              EVALUATION METRICS — MATHEMATICAL FORMULAS          ║
# ╚══════════════════════════════════════════════════════════════════╝
#
# Include these formulas in your report (Chapter 3):
#
# --- Confusion Matrix ---
#                 Predicted Positive   Predicted Negative
# Actual Positive       TP                  FN
# Actual Negative       FP                  TN
#
# --- Metric Formulas ---
#
# 1. Accuracy = (TP + TN) / (TP + TN + FP + FN)
#    → Overall % of correct predictions
#
# 2. Precision = TP / (TP + FP)
#    → Of all predicted positives, how many are truly positive?
#    → Also called "Positive Predictive Value"
#
# 3. Recall (Sensitivity) = TP / (TP + FN)
#    → Of all actual positives, how many did we catch?
#    → Also called "True Positive Rate"
#
# 4. Specificity = TN / (TN + FP)
#    → Of all actual negatives, how many did we correctly reject?
#
# 5. F1 Score = 2 × (Precision × Recall) / (Precision + Recall)
#    → Harmonic mean of Precision and Recall
#    → Balanced metric when classes are imbalanced
#
# 6. Support = Number of actual occurrences of each class
#    → Support(Positive) = TP + FN
#    → Support(Negative) = TN + FP
#
# 7. AUC-ROC:
#    → ROC Curve: plot TPR (Y) vs FPR (X) at different thresholds
#    → FPR (False Positive Rate) = FP / (FP + TN) = 1 - Specificity
#    → AUC = Area under ROC curve (0.5 = random, 1.0 = perfect)
#    → Measures discrimination ability regardless of threshold
#
# 8. Cartesian Curve (Learning Curve):
#    → Plot training size (X) vs accuracy (Y)
#    → Shows how model improves with more data
#    → Helps detect overfitting vs underfitting
# ╔══════════════════════════════════════════════════════════════════╗
# ║                   VIVA QUESTIONS & ANSWERS                       ║
# ╚══════════════════════════════════════════════════════════════════╝
cat("================================================================\n")
cat("        VIVA QUESTIONS & ANSWERS (30 Questions)                \n")
cat("================================================================\n\n")
viva <- list(
list(
q = "Q1. What is the objective of your project?",
a = "To analyze online food delivery data and use ML to predict
profitable business locations, identify peak hours, and provide
data-driven expansion strategies for food delivery platforms."
),
list(
q = "Q2. What dataset did you use?",
a = "A dataset with 2000 records and 17 features covering customer
demographics (age, gender, income), order details (time, meal,
cost), platform (Swiggy/Zomato/ONDC), and city tier."
),
list(
q = "Q3. What is EDA and why is it important?",
a = "Exploratory Data Analysis (EDA) is the process of examining data
through statistics and visualizations to discover patterns, detect
outliers, and understand distributions before building ML models."
),
list(
q = "Q4. How did you handle missing values?",
a = "Numeric columns (Age, Cost) were filled with the MEDIAN (robust
to outliers). Categorical columns (Gender, City) were filled with
the MODE (most frequent value)."
),
list(
q = "Q5. What is your target variable and how did you define it?",
a = "Target: 'High_Demand_Area' (binary: 0 or 1). A location is High
Demand if it meets 2 of 3 criteria: (1) Cost above median,
(2) City Tier 1 or 2, (3) Days since prior order <= 15."
),
list(
q = "Q6. What is a Decision Tree?",
a = "A supervised ML algorithm that splits data into branches based on
feature values using criteria like Gini Index or Information Gain.
It creates a tree-like structure for classification decisions."
),
list(
q = "Q7. What is CART?",
a = "Classification And Regression Tree. It's a type of decision tree
that uses binary splits. We used cross-validation to tune the
complexity parameter (cp) for optimal tree size."
),
list(
q = "Q8. What is Random Forest?",
a = "An ensemble method that builds multiple decision trees (500 in our
case) on random subsets of data and features. Final prediction is
the majority vote of all trees. It reduces overfitting."
),
list(
q = "Q9. What is a Rule-Based Classifier?",
a = "C5.0 generates IF-THEN rules from data. e.g., 'IF Cost > 400 AND
City = Tier1 THEN High_Demand'. Rules are human-readable and
directly usable by business managers."
),
list(
q = "Q10. What is a Confusion Matrix?",
a = "A 2x2 table showing: True Positives (TP), True Negatives (TN),
False Positives (FP), False Negatives (FN). It summarizes all
prediction outcomes."
),
list(
q = "Q11. What is Accuracy?",
a = "Accuracy = (TP + TN) / Total. The percentage of correct predictions
out of all predictions. Limitation: misleading for imbalanced datasets."
),
list(
q = "Q12. What is Precision?",
a = "Precision = TP / (TP + FP). Of all predicted positives, how many
are actually positive? Important when false positives are costly
(e.g., investing in wrong locations)."
),
list(
q = "Q13. What is Recall (Sensitivity)?",
a = "Recall = TP / (TP + FN). Of all actual positives, how many did we
correctly identify? Important when missing a positive is costly
(e.g., missing a profitable city)."
),
list(
q = "Q14. What is F1 Score?",
a = "F1 = 2 × (Precision × Recall) / (Precision + Recall). The harmonic
mean balances precision and recall. Useful when both false positives
and false negatives matter equally."
),
list(
q = "Q15. What is AUC-ROC?",
a = "ROC plots True Positive Rate vs False Positive Rate at different
thresholds. AUC (Area Under Curve) measures overall model quality.
AUC = 0.5 is random, AUC = 1.0 is perfect."
),
list(
q = "Q16. What is Feature Importance?",
a = "It ranks which input features contribute most to predictions.
Random Forest measures this via Mean Decrease Gini. In our project,
Avg_Cost and City_Tier were the most important features."
),
list(
q = "Q17. Why did you choose 70/30 train-test split?",
a = "70% for training gives the model enough data to learn patterns.
30% for testing provides sufficient unseen data to evaluate
generalization. It's the industry standard split."
),
list(
q = "Q18. What is Cross-Validation?",
a = "10-fold CV splits training data into 10 parts, trains on 9, tests
on 1, rotates 10 times. This gives a robust accuracy estimate and
helps tune hyperparameters like cp."
),
list(
q = "Q19. What is Overfitting?",
a = "When a model memorizes training data (including noise) and performs
poorly on new data. Random Forest handles this through ensemble
averaging. CART uses pruning (cp parameter)."
),
list(
q = "Q20. Which model performed best in your project?",
a = "Random Forest typically performs best due to ensemble learning.
Check model_comparison.csv for exact numbers. Best model is
selected by highest AUC-ROC score."
),
list(
q = "Q21. What tools did you use?",
a = "R with RStudio for ML (packages: tidyverse, caret, rpart,
randomForest, C50, pROC). Power BI for interactive dashboards."
),
list(
q = "Q22. What is the Gini Index?",
a = "A measure of impurity used in decision trees. Gini = 1 - sum(pi^2)
where pi is the probability of class i. Lower Gini = purer node.
Trees split to minimize Gini."
),
list(
q = "Q23. What is the difference between Decision Tree and Random Forest?",
a = "Decision Tree: single tree, prone to overfitting, fast, interpretable.
Random Forest: 500+ trees, each on random data subsets, votes for
final answer, more accurate, less interpretable."
),
list(
q = "Q24. How does your project help business decisions?",
a = "It identifies: (1) where to expand (profitable locations),
(2) when to staff more (peak hours), (3) who to target (customer
segments), (4) what restaurants to partner with."
),
list(
q = "Q25. What is the role of Power BI in your project?",
a = "Power BI creates interactive dashboards with KPI cards, charts,
and slicers. Business managers can filter by city, time, platform
to make real-time decisions without coding."
),
list(
q = "Q26. What is Support in classification metrics?",
a = "Support is the number of actual samples in each class in the test
set. e.g., Support(High) = 350 means 350 test samples were actually
High Demand. Used to weight metric reliability."
),
list(
q = "Q27. What is the cp parameter in CART?",
a = "Complexity Parameter controls tree size. Higher cp = simpler tree
(more pruning). We tune it via cross-validation to find the optimal
balance between accuracy and simplicity."
),
list(
q = "Q28. What is Boosting in C5.0?",
a = "Boosting trains multiple models sequentially, each focusing on
samples the previous model got wrong. We used trials=10, meaning
10 boosting rounds for improved accuracy."
),
list(
q = "Q29. What are the limitations of your project?",
a = "1. Dataset is survey-based (2000 records), not real transaction data.
2. No actual GPS coordinates for location analysis.
3. No time-series data for true growth trend analysis.
4. Target variable is derived, not directly from revenue data."
),
list(
q = "Q30. What is the future scope of your project?",
a = "1. Real-time data integration with delivery APIs.
2. Deep Learning (LSTM) for time-series demand forecasting.
3. NLP for customer review sentiment analysis.
4. GPS-based geospatial analysis.
5. Dynamic pricing model.
6. Customer churn prediction."
)
)
# Print all viva Q&A
for (v in viva) {
cat(v$q, "\n")
cat("Answer:", v$a, "\n\n")
}
